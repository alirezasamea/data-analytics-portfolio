      <column caption='Apartment Benchmark' datatype='integer' name='[Apartment_Benchmark]' role='measure' type='quantitative' />
      <column caption='Apartment HPI' datatype='real' name='[Apartment_HPI]' role='measure' type='quantitative' />
      <column caption='Regions Tracked' datatype='integer' name='[Calculation_1470653493407744]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Region])' />
      </column>
      <column caption='Is Selected Region' datatype='boolean' name='[Calculation_1486046843011072]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Region] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='National Avg HPI' datatype='real' name='[Calculation_1486046843248641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Date] : AVG([Composite_HPI]) }' />
      </column>
      <column caption='MoM HPI Change' datatype='real' name='[Calculation_1486046851588099]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Composite_HPI]) - LOOKUP(AVG([Composite_HPI]), -1)) &#13;&#10;/ LOOKUP(AVG([Composite_HPI]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Latest Date' datatype='date' name='[Calculation_1486046853812228]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [Region] : MAX([Date]) }' />
      </column>
      <column caption='Current HPI' datatype='real' name='[Calculation_1486046853885957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date] = [Calculation_1486046853812228] THEN [Composite_HPI] END' />
      </column>
      <column caption='Current Benchmark' datatype='integer' name='[Calculation_1486046855360518]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Date] = [Calculation_1486046853812228] THEN [Composite_Benchmark] END' />
      </column>
      <column caption='Growth Since 2005' datatype='real' name='[Calculation_1486046857089031]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(MAX([Calculation_1486046853885957]) - 100) / 100' />
      </column>
      <column caption='Peak HPI' datatype='real' name='[Calculation_1486046857740296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Region] : MAX([Composite_HPI]) }' />
      </column>
      <column caption='Pct Off Peak' datatype='real' name='[Calculation_1486046857924617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(MAX([Calculation_1486046853885957]) - MAX([Calculation_1486046857740296])) / MAX([Calculation_1486046857740296])' />
      </column>
      <column caption='Composite Benchmark' datatype='integer' name='[Composite_Benchmark]' role='measure' type='quantitative' />
      <column caption='Composite HPI' datatype='real' name='[Composite_HPI]' role='measure' type='quantitative' />
