      <aliases enabled='yes' />
      <column caption='Coordinate' datatype='string' name='[COORDINATE]' role='dimension' type='nominal' />
      <column caption='Employment (Actual)' datatype='real' name='[Calculation_0778236435775488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([VALUE]) * 1000' />
      </column>
      <column caption='Industry Filter' datatype='boolean' name='[Calculation_1221889525841921]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[North American Industry Classification System (NAICS)] = [Parameters].[Parameter 2]' />
      </column>
      <column caption='Is Individual Industry' datatype='boolean' name='[Calculation_1221889529356290]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[North American Industry Classification System (NAICS)] != &quot;Goods-producing sector&quot;&#13;&#10;AND [North American Industry Classification System (NAICS)] != &quot;Services-producing sector&quot;&#13;&#10;AND [North American Industry Classification System (NAICS)] != &quot;Total employed, all industries&quot;' />
      </column>
      <column caption='Industry Name' datatype='string' name='[Calculation_1221889530265603]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [North American Industry Classification System (NAICS)] = &quot;Goods-producing sector&quot;&#13;&#10;OR [North American Industry Classification System (NAICS)] = &quot;Services-producing sector&quot;&#13;&#10;OR [North American Industry Classification System (NAICS)] = &quot;Total employed, all industries&quot;&#13;&#10;THEN NULL&#13;&#10;ELSE [North American Industry Classification System (NAICS)]&#13;&#10;END' />
